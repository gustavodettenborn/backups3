# Backup project environment configuration

# Common paths
BACKUP_HOME="$HOME/developer/backups3"
BACKUP_LOG_DIR="$BACKUP_HOME/logs"
BACKUP_FILTER_FILE="$BACKUP_HOME/backup-filters.txt"

# Google Drive backup script settings
GDRIVE_REMOTE="googledrive"
GDRIVE_FOLDER="backup"
GDRIVE_SOURCE="$HOME/"
GDRIVE_BWLIMIT="08:00,2M 18:00,off"

# S3 backup script settings
S3_REMOTE="gustavodettenbornlaptopbackup"
S3_BUCKET="gustavodettenborn-laptop-backup"
S3_SOURCE="$HOME/Documents/"
S3_BWLIMIT="08:00,2M 18:00,off"

# Runtime/daemon settings
BACKUP_ICON_PATH="$BACKUP_HOME/images/backup.png"
NOTIFY_TIMEOUT_SECONDS="12"
TRAY_TEXT="Backup Google Drive em execucao"
TRAY_ALWAYS_ON_TEXT="Backup Google Drive ativo"
BACKUP_LOOP_INTERVAL_SECONDS="21600"